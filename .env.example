# ============================================================
# GAMIFY — Root Environment Variables for Docker Compose
# Copy this file to .env and fill in real values.
# ============================================================

# ── PostgreSQL Database (for Docker Compose) ─────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=gamify_dev

# ── Backend Secrets — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change_this_to_a_random_64_char_hex_string
JWT_SECRET_KEY=change_this_to_a_different_random_64_char_hex_string

# ── Flask Configuration ────────────────────────────────────
FLASK_ENV=development
CORS_ORIGINS=*

# ── Gunicorn (Optional) ───────────────────────────────────
GUNICORN_WORKERS=2
