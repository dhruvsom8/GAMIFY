# ============================================================
# GAMIFY — Backend Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
# Selects config class: development | production | testing
FLASK_ENV=development

# Flask server port (optional, defaults to 5000)
FLASK_PORT=5000

# ── Security (REQUIRED — generate strong random values) ──────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_SECRET_KEY=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_64_CHAR_HEX_STRING

# ── Database ─────────────────────────────────────────────────
# Development: leave blank to use SQLite (no install needed)
# Production:  set to your PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/gamify_dev

# Test database (only needed when running test suite)
TEST_DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/gamify_test

# ── JWT Token Expiry (optional — these are the defaults) ─────
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── CORS (optional — defaults to * which allows all origins) ─
# In production set this to your actual frontend domain(s)
# Comma-separated list: https://gamify.app,https://www.gamify.app
CORS_ORIGINS=*

# ── Gunicorn (production only) ───────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
