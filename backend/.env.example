# ============================================================
# GAMIFY — Backend Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Flask ────────────────────────────────────────────────────
FLASK_ENV=production

# ── Security — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
JWT_SECRET_KEY=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_64_CHAR_HEX_STRING

# ── Database ─────────────────────────────────────────────────
# Supabase PostgreSQL (production)
DATABASE_URL=postgresql://postgres:gamify@1000@db.zthuftcohkfxwttxppdn.supabase.co:5432/postgres

# Local SQLite fallback (development only — leave DATABASE_URL unset)
# DATABASE_URL=sqlite:///gamify_dev.db

# ── CORS ─────────────────────────────────────────────────────
# Set to your frontend domain in production
CORS_ORIGINS=https://your-frontend.vercel.app

# ── Optional ─────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
FLASK_PORT=5000
