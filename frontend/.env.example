# ============================================================
# GAMIFY — Frontend Environment Variables (Vite)
# Copy this file to .env and fill in real values.
# All VITE_ variables are PUBLIC — bundled into the client JS.
# NEVER put secrets here.
# ============================================================

# ── API URL ──────────────────────────────────────────────────
# Development: leave blank — Vite proxy handles /api → localhost:5000
# Production:  set to your deployed backend URL
VITE_API_URL=https://api.yourdomain.com

# ── App Meta (optional) ──────────────────────────────────────
VITE_APP_NAME=GAMIFY
VITE_APP_VERSION=1.0.0
